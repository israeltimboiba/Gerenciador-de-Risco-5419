rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Project Validation Helper
    function isValidProject(data) {
      return data.name is string && data.name.size() <= 200
        && data.ownerId == request.auth.uid
        && data.length is number
        && data.width is number
        && data.height is number
        && data.ng is number
        && data.keys().hasAll(['name', 'ownerId', 'createdAt'])
        && (data.get('updatedAt', null) == null || data.updatedAt == request.time);
    }

    match /projects/{projectId} {
      allow get: if isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(projectId)
        && isValidProject(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isOwner(existing().ownerId)
        && isValidProject(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
        
      allow delete: if isOwner(existing().ownerId);
    }
  }
}
